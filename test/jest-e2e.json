{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@model/(.*)\\.js$": "<rootDir>/../src/model/$1",
    "^@port/(.*)\\.js$": "<rootDir>/../src/port/$1",
    "^@use-case/(.*)\\.js$": "<rootDir>/../src/use-case/$1",
    "^@controller/(.*)\\.js$": "<rootDir>/../src/controller/$1",
    "^@dto/(.*)\\.js$": "<rootDir>/../src/dto/$1",
    "^@error/(.*)\\.js$": "<rootDir>/../src/error/$1",
    "^@entity/(.*)\\.js$": "<rootDir>/../src/entity/$1",
    "^@adapter/(.*)\\.js$": "<rootDir>/../src/adapter/$1",
    "^@repository/(.*)\\.js$": "<rootDir>/../src/repository/$1",
    "^@infrastructure/(.*)\\.js$": "<rootDir>/../src/infrastructure/$1",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
